{
    "workbench.startupEditor": "none",
    "workbench.editor.enablePreview": false,
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 100,
    "files.exclude": {
        "**/__pycache__": true,
        "**/.idea": true,
        "**/.vscode": true,
        "**/*.ipynb_checkpoints": true,
        "**/*.pyc": true
    },
    "explorer.confirmDragAndDrop": false,
    "git.openRepositoryInParentFolders": "never",
    "editor.minimap.enabled": true,
    "editor.renderWhitespace": "none",
    "editor.inlineSuggest.enabled": true,
    "editor.renderControlCharacters": false,
    "editor.folding": false,
    "editor.glyphMargin": false,
    "editor.inlayHints.enabled": "off",
    "explorer.confirmDelete": false,
    "terminal.integrated.sendKeybindingsToShell": false,
    "terminal.integrated.inheritEnv": false,
    "extensions.ignoreRecommendations": true,
    "security.workspace.trust.untrustedFiles": "open",
    "terminal.external.linuxExec": "ghostty",
    "remote.autoForwardPortsSource": "hybrid",
    "workbench.iconTheme": "Monokai Pro (Filter Octagon) Icons",
    "github.copilot.nextEditSuggestions.enabled": true,
    "security.promptForLocalFileProtocolHandling": false,
    "claudeCode.preferredLocation": "panel",
    "python.defaultInterpreterPath": "/opt/homebrew/bin/python3.13",
    "markdown.math.enabled": true,
    "markdown-preview-enhanced.enablePreviewZenMode": false,
    "markdown-preview-enhanced.previewTheme": "monokai.css",
    "markdown-preview-enhanced.codeBlockTheme": "github-dark.css",
    "files.associations": {
        "*.toml": "toml"
    },
    "remote.SSH.remotePlatform": {
        "tarik-g4.us-east1-b.eka-robotics": "linux",
        "eka-control-4": "linux",
        "192.168.1.104": "linux"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "workbench.activityBar.orientation": "vertical",
    "window.autoDetectColorScheme": false,
    "workbench.colorTheme": "Default Dark Modern"
}